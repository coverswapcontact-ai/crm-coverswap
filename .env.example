# ────────────────────────────────────────────────────────────
# CRM CoverSwap — variables d'environnement
# Copier vers .env.local en dev, ou configurer dans Railway
# ────────────────────────────────────────────────────────────

# Base de données (SQLite)
# Dev:  file:./dev.db
# Prod Railway (volume):  file:/data/crm.db
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="CHANGE_ME_random_32_bytes_hex"
NEXTAUTH_URL="http://localhost:3001"

# Email (Resend)
RESEND_API_KEY="re_xxx"
EMAIL_FROM="CoverSwap <noreply@coverswap.fr>"

# IA (Anthropic)
ANTHROPIC_API_KEY="sk-ant-xxx"

# Webhook — DOIT correspondre à CRM_WEBHOOK_SECRET sur le site
WEBHOOK_SECRET="CHANGE_ME_same_as_site"

# Admin dashboard
ADMIN_PASSWORD="CHANGE_ME_strong_password"

# URL publique
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ── Meta Ads (Lead Ads + Conversions API) ──────────────────
# 1. Créer une app sur https://developers.facebook.com/apps
# 2. Ajouter le produit "Webhooks" + "Marketing API"
# 3. Générer un token d'accès permanent (System User)
META_ACCESS_TOKEN=""
META_PIXEL_ID=""
META_VERIFY_TOKEN="CHANGE_ME_random_string"

# ── Turso (production Vercel uniquement) ───────────────────
# TURSO_DATABASE_URL="libsql://xxx.turso.io"
# TURSO_AUTH_TOKEN=""
